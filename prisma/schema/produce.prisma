model Produce {
  id                String        @id @default(uuid())
  vendorId          String
  vendor            VendorProfile @relation(fields: [vendorId], references: [id])
  name              String
  description       String
  price             Float
  category          String
  availableQuantity Int
  orders            Order[]

  @@unique([vendorId, name])
  @@map("produce")
}
